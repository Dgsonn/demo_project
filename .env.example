# Postgres connection string for the contact-form leads table.
# Get one free at https://neon.tech (or any Postgres host) then copy this
# file to .env.local and fill in the real value.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Email notification when a new lead comes in — sign up free at
# https://resend.com, create an API key, and verify a sending domain
# (or use their onboarding@resend.dev sender while testing).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Address that receives the notification (your sales inbox).
CONTACT_NOTIFY_EMAIL=sales@ptflour.vn
# Sender address — must be on a domain verified in Resend.
CONTACT_FROM_EMAIL=leads@ptflour.vn

# Admin dashboard (/admin) — views submitted leads and updates their status.
# Shared password for the sales team; generate a strong one.
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie — generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=
